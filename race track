# Store tracks and their respective lap times(seconds) in a dictionary
track_times = {
    "Barcelona": 103,
    "Suzuka": 117,
    "Daytona": 104,
    "Melvin": 123,
    "Silverstone": 116,
    "Abu Dhabi": 112,
    "Spa": 150,
    "Nurburgring": 495
}

# Print available tracks
print(f"Available tracks: {list(track_times.keys())}")
print("Choose Track")
user_choice = input()

# Check if the chosen track exists in our dictionary
if user_choice in track_times:
  print("How many laps")
  laps = int(input())
  # Finds the number laps and tells time tacken on those laps for the users choosen track
  lap_time = track_times[user_choice]
  total_time = lap_time * laps
  print(f"Car took {total_time} seconds to finish.")
else:
  print("Not a track choice.")
